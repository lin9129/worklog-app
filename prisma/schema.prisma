generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"

}

model User {
  id             String    @id @default(cuid())
  name           String    @unique
  employmentType String?
  department     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workLogs       WorkLog[]
}

model Product {
  id           String       @id @default(cuid())
  name         String       @unique
  category     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lotSummaries LotSummary[]
  parts        Part[]
  workLogs     WorkLog[]
  processes    Process[]    @relation("ProcessToProduct")
}

model Process {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  workLogs  WorkLog[]
  products  Product[] @relation("ProcessToProduct")
}

model Part {
  id                String    @id @default(cuid())
  name              String    @unique
  modelNumber       String?
  description       String?
  componentCategory String?
  productId         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  product           Product   @relation(fields: [productId], references: [id])
  workLogs          WorkLog[]
}

model WorkLog {
  id                String   @id @default(cuid())
  date              DateTime @default(now())
  productId         String?
  partId            String?
  processId         String?
  userId            String
  lotNumber         String?
  startTime         String
  endTime           String?
  duration          Int?
  overtimeDuration  Int?
  status            String   @default("作業中")
  remarks           String?
  manualProductName String?
  customerName      String?
  department        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  interruptionTime  Int?     @default(0)
  part              Part?    @relation(fields: [partId], references: [id])
  process           Process? @relation(fields: [processId], references: [id])
  product           Product? @relation(fields: [productId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
}

model LotSummary {
  id                String    @id @default(cuid())
  lotNumber         String    @unique
  productId         String?
  manualProductName String?
  customerName      String?
  productionCount   Int?
  productionTime    Int?
  remarks           String?
  deliveryDate      DateTime?
  department        String?
  isCompleted       Boolean   @default(false)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  product           Product?  @relation(fields: [productId], references: [id])
}
