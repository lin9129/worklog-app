// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String    @unique
  employmentType String?   // 正社員 or パート
  workLogs       WorkLog[]
}

model Product {
  id              String             @id @default(cuid())
  name            String             @unique
  parts           Part[]
  processes       Process[]
  workLogs        WorkLog[]
  lotSummaries    LotSummary[]
}

model Process {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  workLogs  WorkLog[]
}

model Part {
  id                String    @id @default(cuid())
  name              String    @unique
  modelNumber       String?
  description       String?
  componentCategory String?   // 所属部材 (屋根, 胴, 扉, 高欄)
  
  product           Product   @relation(fields: [productId], references: [id])
  productId         String

  workLogs          WorkLog[]
}

model WorkLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  
  product   Product  @relation(fields: [productId], references: [id])
  productId String

  part      Part     @relation(fields: [partId], references: [id])
  partId    String

  process   Process  @relation(fields: [processId], references: [id])
  processId String

  user      User     @relation(fields: [userId], references: [id])
  userId    String
  lotNumber String?

  startTime String
  endTime   String?
  duration  Int?     // Duration in minutes
  status    String   @default("作業中")
  remarks   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LotSummary {
  id              String   @id @default(cuid())
  lotNumber       String   // ロット番号
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  productionCount Int?     // 制作台数 (手入力)
  productionTime  Int?     // 制作時間 (手入力・分単位)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([lotNumber, productId])
}
